<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  :root {
    --yellow: #F5C518;
    --yellow-light: #FFF8DC;
    --bg: #f1f1f1;
    --card-bg: #f5f5f5;
    --text-main: #1a1a1a;
    --text-muted: #666666;
    --accent: #F5C518;
    --radius: 4px;
    --shadow: 0 1px 3px rgba(0,0,0,.08);
    --shadow-hover: 0 4px 12px rgba(0,0,0,.12);
    --easing: cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: transparent;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    padding: 0;
  }
  .page { display:flex; gap:24px; max-width:1100px; margin:0 auto; padding:24px 16px; }
  
  /* SIDEBAR */
  .sidebar {
    min-width: 240px;
    max-width: 260px;
    background: var(--yellow);
    border-radius: var(--radius);
    padding: 28px 24px;
    flex-shrink: 0;
    align-self: flex-start;
  }
  .sidebar h2 { font-size:1.5rem; font-weight:700; color:var(--text-main); margin-bottom:4px; }
  .sidebar a.change-link { color:var(--accent); font-size:.875rem; text-decoration:underline; cursor:pointer; }
  .sidebar hr { border:none; border-top:2px solid var(--text-main); margin:16px 0; }
  .sidebar .address { font-size:.875rem; color:var(--text-main); line-height:1.5; margin-bottom:20px; display:flex; gap:6px; }
  .sidebar .address .pin { flex-shrink:0; }
  .sidebar .section-title { font-weight:700; font-size:.9375rem; margin-bottom:8px; }
  .sidebar .info-line { font-size:.875rem; color:var(--text-main); line-height:1.8; display:flex; align-items:center; gap:8px; }
  .sidebar .info-line .ico { width:16px; text-align:center; flex-shrink:0; }

  /* GRID */
  .grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; flex:1; }
  .card {
    background: var(--card-bg);
    border: 1px solid #e0e0e0;
    border-radius: var(--radius);
    padding: 28px 24px 20px;
    text-decoration: none;
    color: var(--text-main);
    display: flex;
    flex-direction: column;
    transition: transform .2s var(--easing), box-shadow .2s var(--easing);
  }
  .card:hover { transform:translateY(-3px); box-shadow:var(--shadow-hover); }
  .card .icon-box {
    width:56px; height:56px;
    background: var(--yellow-light);
    border-radius: 8px;
    display:flex; align-items:center; justify-content:center;
    margin-bottom:16px;
    font-size:28px;
  }
  .card h3 { font-size:1.0625rem; font-weight:600; margin-bottom:auto; line-height:1.3; }
  .card .link-text {
    margin-top:16px;
    font-size:.8125rem;
    font-weight:600;
    color: var(--text-muted);
    letter-spacing:.04em;
    text-transform:uppercase;
    display:flex; align-items:center; gap:4px;
  }


  /* HEADER BAR */
  .header-bar {
    background: #ffffff;
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #e0e0e0;
  }
  .header-bar .logo-area {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .header-bar .logo-dots {
    display: grid;
    grid-template-columns: repeat(3,10px);
    gap: 4px;
  }
  .header-bar .logo-dots span {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--yellow);
  }
  .header-bar .logo-dots span:nth-child(1) { background: var(--text-main); }
  .header-bar .logo-text {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -.02em;
  }
  .header-bar .header-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-main);
    letter-spacing: .02em;
  }
  .header-bar .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: .8125rem;
    color: var(--text-muted);
  }

  /* TOP BAR - NEWS TICKER */
  .top-bar {
    background: var(--yellow);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
    overflow: hidden;
  }
  .top-bar .badge {
    background: var(--text-main);
    color: var(--yellow);
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 3px;
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: .03em;
  }
  .top-bar .ticker-wrap {
    flex: 1;
    overflow: hidden;
    position: relative;
    height: 22px;
  }
  .top-bar .ticker {
    display: flex;
    gap: 60px;
    position: absolute;
    white-space: nowrap;
    animation: ticker-scroll 28s linear infinite;
  }
  .top-bar .ticker span {
    font-size: .875rem;
    font-weight: 500;
    color: var(--text-main);
  }
  .top-bar .ticker span::before {
    content: "•";
    margin-right: 8px;
    color: var(--text-main);
    opacity: .5;
  }
  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width:768px) {
    .page { flex-direction:column; }
    .sidebar { max-width:100%; min-width:auto; }
    .grid { grid-template-columns:1fr; }
    .header-bar { flex-direction:column; gap:8px; text-align:center; }
    .header-bar .header-right { display:none; }
  }
</style>
</head>
